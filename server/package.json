  },
  "dependencies": {
    "@anthropic-ai/sdk": "*",
    "cors": "*",
    "dotenv": "*",
    "express": "*",
    "ws": "*"
  },
  "devDependencies": {
    "@types/cors": "*",
    "@types/express": "*",
    "@types/node": "*",
    "@types/ws": "*",
    "nodemon": "*",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3"
  }
}
